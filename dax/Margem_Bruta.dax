Margem Bruta =


VAR Escolha = SELECTEDVALUE('Tipo de Exibição Margens'[Valor])

RETURN
    SWITCH(
        Escolha,
        0, 'Medidas'[Acumulado Mês] - SUM('Faturamento Mês SD2010 (DQ)'[D2_CUSTMP]) - SUM('Faturamento Mês SD2010 (DQ)'[D2_CUSTGGF]),
        
        1, DIVIDE(
            (
                'Medidas'[Acumulado Mês] - SUM('Faturamento Mês SD2010 (DQ)'[D2_CUSTMP]) - SUM('Faturamento Mês SD2010 (DQ)'[D2_CUSTGGF])
            )
            ,[Acumulado Mês]
        ) * 100
    )